[22.520414, "o", "version: '3.8'\r\n\r\nservices:\r\n  db:\r\n    image: mysql:8.0\r\n    container_name: todo_db\r\n    restart: always\r\n    environment:\r\n      MYSQL_ROOT_PASSWORD: password\r\n      MYSQL_DATABASE: todos_db\r\n    ports:\r\n      - \"3306:3306\"\r\n    volumes:\r\n      - mysql_data:/var/lib/mysql\r\n    healthcheck:\r\n      test: [\"CMD\", \"mysqladmin\", \"ping\", \"-h\", \"localhost\"]\r\n      timeout: 5s\r\n      retries: 10\r\n\r\n  web:\r\n    build: .\r\n    container_name: todo_app\r\n    restart: always\r\n    ports:\r\n      - \"8000:8000\"\r\n    environment:\r\n      MYSQL_HOST: db\r\n      MYSQL_PASSWORD: password\r\n      MYSQL_DB: todos_db\r\n    depends_on:\r\n      db:\r\n        condition: service_healthy\r\n\r\nvolumes:\r\n  mysql_data:"]
